# ============================================================
# Arquivo de exemplo das variáveis de ambiente do projeto.
# Copie para .env e ajuste os valores conforme seu ambiente:
#
#     cp setup/.env.example setup/.env
#
# O arquivo .env é ignorado pelo Git por conter credenciais.
# ============================================================

# Servidor / Aplicação
PROFILE=local
SERVER_PORT=8080
ENABLE_SSL=false
PROMETHEUS_PORT=9091
PROMETHEUS_DOCKER_PORT=9090:9090

# Banco de Dados (PostgreSQL)
# Nota: username e password vêm do AWS Secrets Manager (LocalStack)
# através do spring.config.import no application-local.yaml
JDBC_URL=jdbc:postgresql://localhost:5432/finance_db
DB_NAME=finance_db
DB_PORT=5432
DB_DOCKER_PORT=5432:5432

# Redis
REDIS_HOST=localhost
REDIS_PASSWORD=changeme
REDIS_PORT=6379
REDIS_DOCKER_PORT=6379:6379

# AWS (LocalStack)
AWS_REGION=us-east-1
LOCALSTACK_URL=http://financecontrol-localstack:4566
AWS_ACCESS_KEY=local_access
AWS_SECRET_KEY=local_secret
